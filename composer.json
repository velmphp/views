{
    "name": "velmphp/views",
    "description": "Velm declarative views — ir.ui.view, arch resolve, fluent Authoring builders",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "velmphp/core": "^1.0@dev"
    },
    "autoload": { "psr-4": { "Velm\\Views\\": "src/" } },
    "autoload-dev": {
        "psr-4": { "Velm\\Views\\Tests\\": "tests/" }
    },
    "extra": {
        "laravel": {
            "providers": ["Velm\\Views\\ViewsServiceProvider"]
        },
        "branch-alias": { "dev-main": "1.x-dev" }
    },
    "minimum-stability": "dev"
}
